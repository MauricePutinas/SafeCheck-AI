# ============================================================
# AI SafeCheck Lite — Beispiel-Umgebungsvariablen
# Kopiere diese Datei zu ".env" und passe die Werte an.
# ============================================================

# --- Datenbank (SQLite, lokal) ---
# Standard: lokale SQLite-Datei im prisma-Ordner.
DATABASE_URL="file:./dev.db"

# --- Lemon Squeezy (Lizenz-Vorbereitung) ---
# Diese Werte sind NICHT zwingend, damit die App lokal laeuft.
# Sie werden nur fuer die spaetere Lizenz-Aktivierung / Webhooks gebraucht.
LEMON_SQUEEZY_API_KEY="ls_test_xxxxxxxxxxxxxxxxxxxxxxxx"
LEMON_SQUEEZY_WEBHOOK_SECRET="whsec_xxxxxxxxxxxxxxxxxxxxxxxx"
LEMON_SQUEEZY_STORE_ID="00000"

# Optionale Produkt-/Varianten-IDs fuer die Pricing-Tiers
LEMON_SQUEEZY_VARIANT_LITE=""
LEMON_SQUEEZY_VARIANT_PRO=""
LEMON_SQUEEZY_VARIANT_BUSINESS=""

# --- Optionaler AI-Adapter (NICHT erforderlich) ---
# Der Scanner arbeitet rein regelbasiert. Dieser Adapter ist nur
# ein vorbereitetes Interface und standardmaessig deaktiviert.
AI_ADAPTER_ENABLED="false"
AI_ADAPTER_PROVIDER=""
AI_ADAPTER_API_KEY=""

# --- App ---
# Schluessel fuer einfache Admin-Aktionen (Platzhalter).
APP_ADMIN_TOKEN="change-me-local-admin-token"
